# App
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite file in ./data/app.db)
# DATABASE_URL is built from data_dir automatically

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost

# OpenAI (stage 2)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SEC=15

# SMTP (stage 2; use mailhog profile in docker)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM=noreply@example.com
EMAIL_OWNER=owner@example.com

# Rate limit (stage 2)
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW_SEC=3600
